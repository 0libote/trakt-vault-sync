{
  "name": "trakt-vault-sync",
  "version": "1.0.2",
  "private": true,
  "description": "Sync Trakt watchlists, history, favorites, and ratings into Obsidian notes.",
  "main": "main.js",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0libote/trakt-vault-sync.git"
  },
  "homepage": "https://github.com/0libote/trakt-vault-sync",
  "bugs": "https://github.com/0libote/trakt-vault-sync/issues",
  "scripts": {
    "audit": "bun audit --audit-level=high",
    "dev": "bun esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && bun esbuild.config.mjs production",
    "check": "bun run lint",
    "lint": "eslint src/",
    "test": "esbuild tests/smoke.ts --bundle --platform=node --format=cjs --alias:obsidian=./tests/stub-obsidian.ts --outfile=tests/.smoke.cjs --log-level=warning && bun tests/.smoke.cjs",
    "verify": "bun run audit && bun run test && bun run lint && bun run build"
  },
  "keywords": [
    "obsidian",
    "trakt",
    "obsidian-plugin",
    "sync",
    "watchlist"
  ],
  "author": "0libote",
  "license": "MIT",
  "overrides": {
    "fast-uri": "3.1.2",
    "flatted": "3.4.2",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@typescript-eslint/parser": "^8.63.0",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-obsidianmd": "0.4.1",
    "obsidian": "latest",
    "typescript": "6.0.3"
  }
}
